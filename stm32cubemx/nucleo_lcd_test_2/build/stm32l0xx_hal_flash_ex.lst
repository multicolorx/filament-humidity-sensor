 151:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** /**
 152:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * @brief  Erase the specified FLASH memory Pages 
 153:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * @note   To correctly run this function, the @ref HAL_FLASH_Unlock() function
 154:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         must be called before.
 155:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         Call the @ref HAL_FLASH_Lock() to disable the flash memory access 
 156:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         (recommended to protect the FLASH memory against possible unwanted operation)
 157:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * @param[in]  pEraseInit pointer to an FLASH_EraseInitTypeDef structure that
 158:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         contains the configuration information for the erasing.
 159:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * 
 160:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * @param[out]  PageError pointer to variable  that
 161:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         contains the configuration information on faulty page in case of error
 162:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   *         (0xFFFFFFFF means that all the pages have been correctly erased)
 163:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * 
 164:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   * @retval HAL_StatusTypeDef HAL Status
 165:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   */
 166:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** HAL_StatusTypeDef HAL_FLASHEx_Erase(FLASH_EraseInitTypeDef *pEraseInit, uint32_t *PageError)
 167:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** {
 168:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   HAL_StatusTypeDef status;
 169:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   uint32_t address = 0U;
 170:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   
 171:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   /* Process Locked */
 172:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   __HAL_LOCK(&pFlash);
 173:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** 
 174:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   /* Wait for last operation to be completed */
 175:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****   status = FLASH_WaitForLastOperation(FLASH_TIMEOUT_VALUE);
