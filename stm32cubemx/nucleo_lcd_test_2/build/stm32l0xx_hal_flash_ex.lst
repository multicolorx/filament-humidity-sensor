 640:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****     FLASH->PEKEYR = FLASH_PEKEY1;
 641:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****     FLASH->PEKEYR = FLASH_PEKEY2;
 642:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** 
