 340:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c **** #endif
 341:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_flash_ex.c ****     if (status != HAL_OK)
