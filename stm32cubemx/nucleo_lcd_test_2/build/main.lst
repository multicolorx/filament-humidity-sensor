 260:Core/Src/main.c ****   uint32_t seg_mask = LCD_ComposeSegBit(0) | LCD_ComposeSegBit(1) |
 261:Core/Src/main.c ****                       LCD_ComposeSegBit(2) | LCD_ComposeSegBit(3) |
 262:Core/Src/main.c ****                       LCD_ComposeSegBit(4) | LCD_ComposeSegBit(5);
 263:Core/Src/main.c **** 
 264:Core/Src/main.c ****   /* Per your measured wiring, each digit has 2 SEG lines:
 265:Core/Src/main.c ****    * line_abc drives {a,b,c} = {top, top-right, bottom-right}
 266:Core/Src/main.c ****    * line_defg drives {d,e,f,g} = {bottom, bottom-left, top-left, middle}
 267:Core/Src/main.c ****    *
 268:Core/Src/main.c ****    * Exact pin map provided:
 269:Core/Src/main.c ****    * LCD pin1 -> A1  -> SEG0  -> digit3 abc (left)
 270:Core/Src/main.c ****    * LCD pin2 -> A3  -> SEG5  -> digit3 defg (left)
 271:Core/Src/main.c ****    * LCD pin3 -> D3  -> SEG7  -> digit2 abc (middle)
 272:Core/Src/main.c ****    * LCD pin4 -> D5  -> SEG8  -> digit2 defg (middle)
 273:Core/Src/main.c ****    * LCD pin5 -> D4  -> SEG9  -> digit1 abc (right)
 274:Core/Src/main.c ****    * LCD pin6 -> D6  -> SEG10 -> digit1 defg (right)
 275:Core/Src/main.c ****    *
 276:Core/Src/main.c ****    * Therefore (right,middle,left):
 277:Core/Src/main.c ****    * abc lines  = SEG9, SEG7, SEG0
 278:Core/Src/main.c ****    * defg lines = SEG10, SEG8, SEG5
 279:Core/Src/main.c ****    *
 280:Core/Src/main.c ****    * COM mapping from your notes:
 281:Core/Src/main.c ****    * COM0=d
 282:Core/Src/main.c ****    * COM1=c/e
 283:Core/Src/main.c ****    * COM2=b/g
 284:Core/Src/main.c ****    * COM3=a/f
 285:Core/Src/main.c ****    */
 286:Core/Src/main.c ****   {
 287:Core/Src/main.c ****     uint8_t abc_seg_idx[3] = {4U, 2U, 0U};
 288:Core/Src/main.c ****     uint8_t defg_seg_idx[3] = {5U, 3U, 1U};
 289:Core/Src/main.c **** 
 290:Core/Src/main.c ****   for (pos = 0U; pos < 3U; pos++)
 291:Core/Src/main.c ****   {
 292:Core/Src/main.c ****     uint8_t p = font7[digits[pos]];
 293:Core/Src/main.c ****     uint32_t line_abc = LCD_ComposeSegBit(abc_seg_idx[pos]);
 294:Core/Src/main.c ****     uint32_t line_defg = LCD_ComposeSegBit(defg_seg_idx[pos]);
 295:Core/Src/main.c **** 
 296:Core/Src/main.c ****     if ((p & (1U << 3)) != 0U) com_data[0] |= line_defg; /* d -> COM0 via defg line */
 297:Core/Src/main.c ****     if ((p & (1U << 2)) != 0U) com_data[1] |= line_abc;  /* c -> COM1 via abc line */
 298:Core/Src/main.c ****     if ((p & (1U << 4)) != 0U) com_data[1] |= line_defg; /* e -> COM1 via defg line */
 299:Core/Src/main.c ****     if ((p & (1U << 1)) != 0U) com_data[2] |= line_abc;  /* b -> COM2 via abc line */
 300:Core/Src/main.c ****     if ((p & (1U << 6)) != 0U) com_data[2] |= line_defg; /* g -> COM2 via defg line */
 301:Core/Src/main.c ****     if ((p & (1U << 0)) != 0U) com_data[3] |= line_abc;  /* a -> COM3 via abc line */
 302:Core/Src/main.c ****     if ((p & (1U << 5)) != 0U) com_data[3] |= line_defg; /* f -> COM3 via defg line */
 303:Core/Src/main.c ****   }
 304:Core/Src/main.c ****   }
 305:Core/Src/main.c **** 
 306:Core/Src/main.c ****   if (HAL_LCD_Clear(&hlcd) != HAL_OK) Error_Handler();
 307:Core/Src/main.c ****   if (HAL_LCD_Write(&hlcd, LCD_RAM_REGISTER0, seg_mask, com_data[0]) != HAL_OK) Error_Handler();
 308:Core/Src/main.c ****   if (HAL_LCD_Write(&hlcd, LCD_RAM_REGISTER2, seg_mask, com_data[1]) != HAL_OK) Error_Handler();
 309:Core/Src/main.c ****   if (HAL_LCD_Write(&hlcd, LCD_RAM_REGISTER4, seg_mask, com_data[2]) != HAL_OK) Error_Handler();
ARM GAS  C:\Users\Tilen\AppData\Local\Temp\cc6ISDp8.s 			page 9


 310:Core/Src/main.c ****   if (HAL_LCD_Write(&hlcd, LCD_RAM_REGISTER6, seg_mask, com_data[3]) != HAL_OK) Error_Handler();
 311:Core/Src/main.c ****   if (HAL_LCD_UpdateDisplayRequest(&hlcd) != HAL_OK) Error_Handler();
 312:Core/Src/main.c **** }
