 223:Core/Src/main.c **** static uint32_t LCD_ComposeSegBit(uint8_t seg_index)
 224:Core/Src/main.c **** {
 225:Core/Src/main.c ****   /* These are the 6 SEG lines currently wired to the glass. */
 226:Core/Src/main.c ****   static const uint8_t seg_bits[6] = {0U, 5U, 7U, 8U, 9U, 10U};
 227:Core/Src/main.c ****   return (1UL << seg_bits[seg_index]);
 228:Core/Src/main.c **** }
 229:Core/Src/main.c **** 
 230:Core/Src/main.c **** static uint16_t MockHumidityX10(void)
 231:Core/Src/main.c **** {
 232:Core/Src/main.c ****   static uint32_t lcg = 0x1A2B3C4DU;
 233:Core/Src/main.c ****   lcg = (lcg * 1664525UL) + 1013904223UL;
 234:Core/Src/main.c ****   return (uint16_t)(lcg % 1000UL); /* 0.0 .. 99.9 %RH */
 235:Core/Src/main.c **** }
