 158:Core/Src/main.c **** static HAL_StatusTypeDef SHT40_ReadRaw(uint16_t *temperature_ticks, uint16_t *humidity_ticks)
 159:Core/Src/main.c **** {
 160:Core/Src/main.c ****   uint8_t cmd = SHT40_CMD_MEASURE_HIGH;
 161:Core/Src/main.c ****   uint8_t rx[6];
 162:Core/Src/main.c **** 
 163:Core/Src/main.c ****   if (HAL_I2C_Master_Transmit(&hi2c2, SHT40_I2C_ADDR, &cmd, 1U, 100U) != HAL_OK)
 164:Core/Src/main.c ****   {
 165:Core/Src/main.c ****     return HAL_ERROR;
 166:Core/Src/main.c ****   }
 167:Core/Src/main.c **** 
 168:Core/Src/main.c ****   HAL_Delay(10U);
 169:Core/Src/main.c **** 
 170:Core/Src/main.c ****   if (HAL_I2C_Master_Receive(&hi2c2, SHT40_I2C_ADDR, rx, sizeof(rx), 100U) != HAL_OK)
 171:Core/Src/main.c ****   {
 172:Core/Src/main.c ****     return HAL_ERROR;
 173:Core/Src/main.c ****   }
 174:Core/Src/main.c **** 
 175:Core/Src/main.c ****   if (SHT40_Crc8(&rx[0], 2U) != rx[2] || SHT40_Crc8(&rx[3], 2U) != rx[5])
 176:Core/Src/main.c ****   {
 177:Core/Src/main.c ****     return HAL_ERROR;
 178:Core/Src/main.c ****   }
 179:Core/Src/main.c **** 
 180:Core/Src/main.c ****   *temperature_ticks = (uint16_t)(((uint16_t)rx[0] << 8) | rx[1]);
 181:Core/Src/main.c ****   *humidity_ticks = (uint16_t)(((uint16_t)rx[3] << 8) | rx[4]);
 182:Core/Src/main.c **** 
 183:Core/Src/main.c ****   return HAL_OK;
 184:Core/Src/main.c **** }
 185:Core/Src/main.c **** 
 186:Core/Src/main.c **** static void SHT40_TestLoop(void)
 187:Core/Src/main.c **** {
 188:Core/Src/main.c ****   uint16_t temperature_ticks;
 189:Core/Src/main.c ****   uint16_t humidity_ticks;
 190:Core/Src/main.c ****   float temperature_c;
 191:Core/Src/main.c ****   float humidity_rh;
 192:Core/Src/main.c **** 
 193:Core/Src/main.c ****   if (HAL_I2C_IsDeviceReady(&hi2c2, SHT40_I2C_ADDR, 3U, 100U) != HAL_OK)
 194:Core/Src/main.c ****   {
 195:Core/Src/main.c ****     DebugPrint("SHT40 not responding at 0x44\r\n");
ARM GAS  C:\Users\Tilen\AppData\Local\Temp\cc6ISDp8.s 			page 7


 196:Core/Src/main.c ****     HAL_Delay(1000U);
 197:Core/Src/main.c ****     return;
 198:Core/Src/main.c ****   }
 199:Core/Src/main.c **** 
 200:Core/Src/main.c ****   if (SHT40_ReadRaw(&temperature_ticks, &humidity_ticks) != HAL_OK)
 201:Core/Src/main.c ****   {
 202:Core/Src/main.c ****     DebugPrint("SHT40 read failed\r\n");
 203:Core/Src/main.c ****     HAL_Delay(1000U);
 204:Core/Src/main.c ****     return;
 205:Core/Src/main.c ****   }
 206:Core/Src/main.c **** 
 207:Core/Src/main.c ****   temperature_c = -45.0f + (175.0f * (float)temperature_ticks / 65535.0f);
 208:Core/Src/main.c ****   humidity_rh = -6.0f + (125.0f * (float)humidity_ticks / 65535.0f);
 209:Core/Src/main.c **** 
 210:Core/Src/main.c ****   if (humidity_rh < 0.0f)
 211:Core/Src/main.c ****   {
 212:Core/Src/main.c ****     humidity_rh = 0.0f;
 213:Core/Src/main.c ****   }
 214:Core/Src/main.c ****   else if (humidity_rh > 100.0f)
 215:Core/Src/main.c ****   {
 216:Core/Src/main.c ****     humidity_rh = 100.0f;
 217:Core/Src/main.c ****   }
 218:Core/Src/main.c **** 
 219:Core/Src/main.c ****   DebugPrintf("SHT40 OK  T=%.2f C  RH=%.2f %%\r\n", temperature_c, humidity_rh);
 220:Core/Src/main.c ****   HAL_Delay(1000U);
 221:Core/Src/main.c **** }
