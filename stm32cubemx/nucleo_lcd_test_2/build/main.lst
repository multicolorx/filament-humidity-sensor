 237:Core/Src/main.c **** static void LCD_DisplayNumber3(uint16_t value)
 238:Core/Src/main.c **** {
 239:Core/Src/main.c ****   /* 7-segment font: bits = a b c d e f g in bit positions 0..6. */
 240:Core/Src/main.c ****   static const uint8_t font7[10] =
 241:Core/Src/main.c ****   {
 242:Core/Src/main.c ****     0x3FU, /* 0 */
