 244:Core/Src/main.c ****     0x5BU, /* 2 */
 245:Core/Src/main.c ****     0x4FU, /* 3 */
 246:Core/Src/main.c ****     0x66U, /* 4 */
 247:Core/Src/main.c ****     0x6DU, /* 5 */
 248:Core/Src/main.c ****     0x7DU, /* 6 */
 249:Core/Src/main.c ****     0x07U, /* 7 */
 250:Core/Src/main.c ****     0x7FU, /* 8 */
 251:Core/Src/main.c ****     0x6FU  /* 9 */
 252:Core/Src/main.c ****   };
