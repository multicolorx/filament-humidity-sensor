1029:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c **** 
1030:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****     (#) Non-Blocking mode transfers could be aborted using Abort API's :
1031:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_Abort()
1032:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_AbortTransmit()
1033:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_AbortReceive()
