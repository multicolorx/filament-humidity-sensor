1025:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_TxCpltCallback()
1026:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_RxHalfCpltCallback()
1027:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_RxCpltCallback()
