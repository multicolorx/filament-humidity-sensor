1018:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_Receive_DMA()
1019:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_DMAPause()
1020:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_DMAResume()
1021:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****         (++) HAL_UART_DMAStop()
1022:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c **** 
1023:Drivers/STM32L0xx_HAL_Driver/Src/stm32l0xx_hal_uart.c ****     (#) A set of Transfer Complete Callbacks are provided in Non_Blocking mode:
